<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Portfolio</title>
  <style>
    :root {
      --msu-green: #18453B;
      --white: #ffffff;
      --light-gray: #f5f5f5;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      background-color: var(--white);
      color: var(--msu-green);
    }

    header {
      background-color: var(--msu-green);
      color: var(--white);
      padding: 20px;
      text-align: center;
    }

    nav {
      display: flex;
      justify-content: center;
      gap: 20px;
      margin-top: 10px;
    }

    nav a {
      color: var(--white);
      text-decoration: none;
      font-weight: bold;
    }

    section {
      padding: 60px 20px;
      max-width: 1000px;
      margin: auto;
    }

    .hero {
      text-align: center;
    }

    .hero h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .projects {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: var(--light-gray);
      padding: 20px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-5px);
    }

    footer {
      background-color: var(--msu-green);
      color: var(--white);
      text-align: center;
      padding: 15px;
    }

    .btn {
      display: inline-block;
      margin-top: 15px;
      padding: 10px 20px;
      background-color: var(--msu-green);
      color: var(--white);
      text-decoration: none;
      border-radius: 5px;
    }
  </style>
</head>
<body>

  <header>
    <h1>Your Name</h1>
    <p>Student | Portfolio</p>
    <nav>
      <a href="#about">About</a>
      <a href="#projects">Projects</a>
      <a href="#contact">Contact</a>
    </nav>
  </header>

  <section class="hero">
    <h1>Hi, I'm Your Name</h1>
    <p>I’m a student at Michigan State University studying Information Science.</p>
    <a href="#projects" class="btn">View My Work</a>
  </section>

  <section id="about">
    <h2>About Me</h2>
    <p>Write a short paragraph about yourself, your interests, and your career goals.</p>
  </section>

  <section id="projects">
    <h2>Projects</h2>
    <div class="projects">
      <div class="card">
        <h3>Project 1</h3>
        <p>Short description of your project.</p>
      </div>
      <div class="card">
        <h3>Project 2</h3>
        <p>Short description of your project.</p>
      </div>
      <div class="card">
        <h3>Project 3</h3>
        <p>Short description of your project.</p>
      </div>
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>Email: your.email@example.com</p>
  </section>

  <footer>
    <p>© 2026 Your Name</p>
  </footer>

</body>
</html>
